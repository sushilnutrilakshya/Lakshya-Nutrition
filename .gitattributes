# Normalize line endings for the entire repo.
# Git will convert CRLF to LF on commit, and leave as LF on checkout.
# This ensures consistent line endings across Windows, macOS, and Linux.

* text=auto eol=lf

# Force LF for all source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.mdx  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf
*.sh   text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
